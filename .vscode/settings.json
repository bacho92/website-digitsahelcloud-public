{
    "editor.formatOnSave": true,
    "editor.tabSize": 4,
    "editor.defaultFormatter": "bmewburn.vscode-intelephense-client",
    "files.associations": {
        "*.blade.php": "blade"
    },
    "emmet.includeLanguages": {
        "blade": "html"
    },
    "tailwindCSS.includeLanguages": {
        "blade": "html"
    },
    "git.autofetch": true,
    "git.confirmSync": false,
    "editor.rulers": [120],
    "files.eol": "\n"
}